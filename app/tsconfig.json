{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "lib": ["dom", "es2024"],
    "esModuleInterop": true,
    "moduleDetection": "auto",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "emitBOM": false,
    "removeComments": true,
    "alwaysStrict": true,
    "noEmitOnError": false,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "diagnostics": true,
    "listEmittedFiles": true,
    "types": ["jquery"]
  },
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Recommended",
  "include": [
    "src/**/*.ts",
    "lib/**/*.d.ts"
  ],
  "exclude": [
    "node_modules/*",
    "./dist"
  ]
}